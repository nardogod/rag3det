# Caminho dos PDFs usados para construir o índice localmente.
# Em um clone novo, use `data/raw` ou aponte para outra pasta no seu computador.
SOURCE_PDF_DIR="data/raw"

# Diretório onde o ChromaDB vai persistir o índice vetorial
CHROMA_DB_DIR="data/chroma"

# Modelo de embeddings multilíngue (bom para português)
EMBEDDING_MODEL_NAME="sentence-transformers/paraphrase-multilingual-mpnet-base-v2"

# Provedor de LLM: "ollama" ou "openai".
# Para deploy público, prefira OpenAI ou outro provedor remoto.
LLM_PROVIDER="openai"

# Configuração para Ollama (descomente para uso local; em deploy comum isso não funciona)
OLLAMA_MODEL="gemma3:4b"
OLLAMA_BASE_URL="http://localhost:11434"

# Configuração para OpenAI (recomendado para deploy)
OPENAI_API_KEY="SUA_CHAVE_AQUI"
OPENAI_MODEL_NAME="gpt-4.1-mini"

# Em deploy público, prefira deixar a reconstrução do índice desabilitada
# e subir o app com um índice já preparado.
ENABLE_INDEX_REBUILD="false"

# Quantos trechos enviar ao LLM (após rerank)
RETRIEVAL_K="6"
# Candidatos antes do rerank (retrieve 20 → cross-encoder → top RETRIEVAL_K)
RETRIEVAL_CANDIDATE_K="20"
# Cross-encoder: relevância real query↔chunk (evita Fênix → Solar/Pégaso)
# Para respostas mais rápidas: RERANKING_ENABLED="false"
RERANKING_ENABLED="true"
# Expansão de query com termos 3D&T (Fênix → magia fogo, etc.)
# Para respostas mais rápidas: QUERY_EXPANSION_ENABLED="false"
QUERY_EXPANSION_ENABLED="true"

